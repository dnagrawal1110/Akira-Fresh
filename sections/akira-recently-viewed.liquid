{%- doc -%}
  Recently viewed products. Stores the current product in localStorage and
  renders previously viewed products (client-side). Hides itself when empty.
{%- enddoc -%}

{%- liquid
  assign p = closest.product | default: product
  assign v = p.selected_or_first_available_variant
  assign img = p.featured_image | image_url: width: 400
-%}

<div
  class="section section--page-width akira-rv"
  data-akira-rv
  hidden
  data-handle="{{ p.handle }}"
  data-url="{{ p.url }}"
  data-title="{{ p.title | escape }}"
  data-img="{{ img }}"
  data-price="{{ v.price | money }}"
>
  <h2 class="akira-rv__title">{{ section.settings.heading | default: 'Recently viewed' }}</h2>
  <div class="akira-rv__grid" data-akira-rv-grid></div>
</div>

<script>
  (function () {
    var root = document.querySelector('[data-akira-rv]');
    if (!root) return;
    var KEY = 'akira_recently_viewed';
    var cur = {
      handle: root.dataset.handle,
      url: root.dataset.url,
      title: root.dataset.title,
      img: root.dataset.img,
      price: root.dataset.price
    };
    var list = [];
    try { list = JSON.parse(localStorage.getItem(KEY)) || []; } catch (e) {}
    var others = list.filter(function (i) { return i && i.handle !== cur.handle; });

    // Save current to the front, cap at 8
    if (cur.handle) {
      var next = [cur].concat(others).slice(0, 8);
      try { localStorage.setItem(KEY, JSON.stringify(next)); } catch (e) {}
    }

    if (!others.length) return;

    var grid = root.querySelector('[data-akira-rv-grid]');
    grid.innerHTML = others.slice(0, 5).map(function (i) {
      return '<a class="akira-rv__card" href="' + i.url + '">' +
        '<span class="akira-rv__media"><img loading="lazy" src="' + i.img + '" alt="' + (i.title || '') + '"></span>' +
        '<span class="akira-rv__name">' + (i.title || '') + '</span>' +
        '<span class="akira-rv__price">' + (i.price || '') + '</span>' +
        '</a>';
    }).join('');
    root.hidden = false;
  })();
</script>

{% stylesheet %}
  .akira-rv { padding-block: 8px 40px; }
  .akira-rv__title { font-size: 1.25rem; font-weight: 600; color: #263238; margin: 0 0 16px; }
  .akira-rv__grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }
  .akira-rv__card { display: flex; flex-direction: column; gap: 6px; text-decoration: none; color: #263238; }
  .akira-rv__media { display: block; border-radius: 12px; overflow: hidden; aspect-ratio: 1/1; background: #F7F4EE; }
  .akira-rv__media img { width: 100%; height: 100%; object-fit: cover; }
  .akira-rv__name { font-size: 0.9rem; line-height: 1.3; }
  .akira-rv__price { font-size: 0.9rem; font-weight: 600; color: #1B5E20; }
  @media screen and (max-width: 749px) {
    .akira-rv__grid { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Akira recently viewed",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Recently viewed" }
  ],
  "presets": [{ "name": "Akira recently viewed" }]
}
{% endschema %}
